rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entities Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() <= 256;
    }

    function isValidCalendar(data) {
      return data.keys().hasAll(['userId', 'month', 'year']) &&
             data.userId == request.auth.uid &&
             data.month is string &&
             data.year is int;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['calendarId', 'network', 'day', 'content']) &&
             data.network in ['X', 'LinkedIn', 'YouTube', 'TikTok', 'Instagram', 'Facebook'] &&
             data.day is int &&
             data.content is string &&
             data.content.size() <= 5000;
    }

    function isValidCampaign(data) {
      return data.keys().hasAll(['userId', 'name', 'status']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() <= 200 &&
             data.status in ['active', 'closed'];
    }

    function isValidMetric(data) {
      return data.keys().hasAll(['referenceId', 'type']) &&
             data.type in ['post', 'campaign'];
    }

    function isValidAgentSession(data) {
      return data.keys().hasAll(['userId', 'agentId', 'prompt', 'response']) &&
             data.userId == request.auth.uid &&
             data.prompt is string &&
             data.response is string;
    }

    function isValidCalendarEvent(data) {
      return data.keys().hasAll(['userId', 'campaignId', 'title', 'networkId', 'date', 'status']) &&
             data.userId == request.auth.uid &&
             data.campaignId is string &&
             data.title is string &&
             data.networkId in ['X', 'LinkedIn', 'YouTube', 'TikTok', 'Instagram', 'Facebook'];
    }

    function isValidAdCampaign(data) {
      return data.keys().hasAll(['userId', 'campaignId', 'name', 'platform', 'budget', 'spent', 'status']) &&
             data.userId == request.auth.uid &&
             data.campaignId is string &&
             data.platform in ['Meta Ads', 'TikTok Ads', 'Google Ads'] &&
             data.status in ['Active', 'Reviewing', 'Paused'];
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /contentCalendars/{calendarId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCalendar(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidCalendar(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      match /posts/{postId} {
        allow list, get: if isSignedIn() && get(/databases/$(database)/documents/contentCalendars/$(calendarId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/contentCalendars/$(calendarId)).data.userId == request.auth.uid && isValidPost(request.resource.data);
        allow update: if isSignedIn() && get(/databases/$(database)/documents/contentCalendars/$(calendarId)).data.userId == request.auth.uid && isValidPost(request.resource.data);
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/contentCalendars/$(calendarId)).data.userId == request.auth.uid;
      }
    }

    match /campaigns/{campaignId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCampaign(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidCampaign(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /metrics/{metricId} {
      allow list, get: if isSignedIn(); // Add more specific checks if needed
      allow create: if isSignedIn() && isValidMetric(request.resource.data);
    }

    match /agentSessions/{sessionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAgentSession(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /calendarEvents/{eventId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCalendarEvent(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidCalendarEvent(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /adCampaigns/{adId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAdCampaign(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidAdCampaign(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
